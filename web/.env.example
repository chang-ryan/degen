# Supabase-backed reads. Set these for prod (Vercel) or to test the Supabase
# path locally. Leave them UNSET to use the local SQLite file (default dev).
#
# Use the new-format PUBLISHABLE key (sb_publishable_…) — it's browser-safe and
# read-only via RLS. Never put the secret key here or in Vercel's frontend env.
# (Legacy anon key also works via SUPABASE_ANON_KEY.)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
