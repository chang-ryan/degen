# Copy to `.env` (gitignored) and fill in. All keys are optional — the macro gauges
# run with none of them; each integration just needs its own.

# --- Dashboard export → Supabase (degen.webexport) ---
# The new-format SECRET key (sb_secret_…) — can write, bypasses RLS. Stays on this
# machine only; never put it in web/ or Vercel. The web app uses the publishable key.
# (Legacy service_role key also works via SUPABASE_SERVICE_KEY.)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# --- Discord ingest (degen/ingest) ---
DISCORD_BOT_TOKEN=

# --- E*TRADE (long-term book; OAuth 1.0a) ---
ETRADE_API_KEY=
ETRADE_API_SECRET=
ETRADE_ENV=prod          # prod | sandbox

# --- SEC EDGAR (filings) ---
# SEC requires a descriptive UA: "Name email@example.com"
SEC_USER_AGENT=
